                }
              }
            }
          }
        }
      }
    },
    "/v1/otp_login": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "summary": "OTP Login",
        "description": "Login using a verification token and public key.",
        "operationId": "OtpLogin",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OtpLoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
